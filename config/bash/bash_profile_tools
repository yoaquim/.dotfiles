# direnv
# ───────────────────────────────────────────────────
if command -v direnv &> /dev/null
then
    eval "$(direnv hook bash)"
fi


# ngrok 
# ───────────────────────────────────────────────────
if command -v ngrok &>/dev/null; then
  eval "$(ngrok completion)"
fi

